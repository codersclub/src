<script language="JavaScript"><!--
function gourl(s) {
  window.top.location.href = s;
}
function check() {
 if (!document.myform.login.value) {
   alert("Нужно заполнить поле\n LOGIN");
   document.myform.login.focus();
   return false;
 }
 if (!document.myform.pass.value) {
   alert("Нужно заполнить поле\n PASSWORD");
   document.myform.pass.focus();
   return false;
 }
 if (!document.myform.title.value) {
   alert("Нужно заполнить поле\n ЗАГОЛОВОК");
   document.myform.title.focus();
   return false;
 }
 if (!document.myform.author.value) {
   alert("Нужно заполнить поле\n АВТОР");
   document.myform.author.focus();
   return false;
 }
 if (!document.myform.description.value) {
   alert("Нужно заполнить поле\n КРАТКОЕ ОПИСАНИЕ");
   document.myform.description.focus();
   return false;
 }
 if (!document.myform.keywords.value) {
   alert("Нужно заполнить поле\n КЛЮЧЕВЫЕ СЛОВА");
   document.myform.keywords.focus();
   return false;
 }
 if (!(document.myform.filename.value || document.myform.descriptionfile.value)) {
   alert("Нужно заполнить хотя бы одно из полей:\n ПОДРОБНОЕ ОПИСАНИЕ\n или ФАЙЛ ДЛЯ СКАЧИВАНИЯ");
   document.myform.descriptionfile.focus();
   return false;
 }
 return true;
}

function clearall() {
 document.myform.login.value="";
 document.myform.pass.value="";
 document.myform.title.value="";
 document.myform.author.value="";
 document.myform.authoremail.value="";
 document.myform.description.value="";
 document.myform.keywords.value="";
 document.myform.descriptionfile.value="";
 document.myform.filename.value="";
 return true;
}
//--></script>

</HEAD><BODY><CENTER>

