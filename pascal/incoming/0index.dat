MEMORY|lcol|Large Collection|Александр|alex@tax.Info.Kurgan.Ru|Реализация коллекции с количеством элементов &gt;16384 |длинные коллекции|В процессе пользования стандартного Tcollection из модуля<br>Objects бавают ситуации, когда кол-во элементов превышает<br>16384 единицы. Предлагаемый модуль реализует объект-коллекцию<br>с любым количеством элементов (на сколько хватит памяти Вашего<br>компьютера)<br><br>{Реализация коллекции с любым количеством элементов для Bp 7.0<br>Protected Mode Стандартная Tcollection позволяет работать максимум<br>с 16384 указателями.<br>В предложенной реализации этот недостаток устранен.<br>Большой минус - не реализована сортировка<br>Объект усиленно пользовался в течении 2 лет, вроде все ошибки<br>устранены, на автор не гарантирует, что все работает правильно.<br>Сейчас идет усиленная работа по реализации методов на асме.<br>По всем вопросам обращаться alex@tax.Info.Kurgan.Ru}<br><br><pre>Unit Lcol;<br>Interface<br>Uses Objects;<br><br>Type Plcol=^TlCol;<br>     Tlcol=Object(Tobject)<br>       Count:Longint;<br>       Bas:Pcollection;                  {Коллекция коллекций}<br>       Start,Delta:Longint;<br>       Tec:Pcollection;                  {Текущая}<br>       Inx,Ts:Integer;<br>       Constructor Init(Astart,Adelta:Longint);<br>       Destructor  Done;Virtual;<br>       {Вернуть элемент с индексом Index}<br>       Function    At(Index:Longint):Pointer;Virtual;<br>       {Удалить элемент с индексом Index}<br>       Procedure   AtDelete(Index:Longint);Virtual;<br>       {Освободить элемент}<br>       Procedure   AtFree(Index:Longint);Virtual;<br>       {Вставить элемент на позицию Index}<br>       Procedure   AtInsert(Index:Longint;Item:Pointer);Virtual;<br>       {Заменить элемент}<br>       Procedure   AtPut(Index:Longint;Item:Pointer);Virtual;<br>       {Удалить элемент}<br>       Procedure   Delete(Item:pointer);Virtual;<br>       {Удалить все}<br>       Procedure   DeleteAll;Virtual;<br>       {применить функцию к каждому элементу и найти первый элемент}<br>       Function    FirstThat(p:Pointer):Pointer;Virtual;<br>       {применить процеду к каждому элементу}<br>       Procedure   ForEach(p:Pointer);Virtual;<br>       {Освободить элемент}<br>       Procedure   Free(Item:Pointer);Virtual;<br>       {Освободить все}<br>       Procedure   FreeAll;Virtual;<br>       {Освободить элемент по адресу}<br>       Procedure   FreeItem(Item:Pointer);Virtual;<br>       {Вернуть индекс элемента}<br>       Function    IndexOf(Item:Pointer):Longint;Virtual;<br>       {Добавить элемент}<br>       Procedure   Insert(Item:Pointer);Virtual;<br>       {применить функцию в обратном порядке}<br>       Function    LastThat(p:Pointer):Pointer;Virtual;<br>       {Расчитать базу-смещение}<br>       Procedure   SH(l:longint);Virtual;<br>     End;<br><br>Implementation<br><br>Constructor TlCol.Init;<br>var dan:Pcollection;<br>Begin<br>     Inherited Init;<br>     Delta:=Adelta;<br>     start:=Astart;<br>     Bas:=New(Pcollection,Init(1,1));<br>     Dan:=New(Pcollection,Init(start,Delta));<br>     Bas^.Insert(Dan);<br>     Tec:=Nil;<br>     Count:=0;<br>End;<br><br>Destructor Tlcol.Done;<br>Begin<br>     Dispose(Bas,Done);<br>     Inherited Done;<br>End;<br><br>Function Tlcol.At(Index:Longint):Pointer;<br>Begin<br>    Sh(Index);<br>    At:=Tec^.At(Inx);<br>End;<br><br>Procedure Tlcol.AtDelete(Index:Longint);<br>var p:Pointer;<br>    Pc:Pcollection;<br>Begin<br>     Sh(Index);<br>     Tec^.AtDelete(Inx);<br>     Dec(Count);<br>     if ts=Bas^.Count-1 then exit;<br>     While ts<Bas^.Count-1 do<br>     Begin<br>          Pc:=Bas^.At(ts+1);  {Взять следующую колекцию}<br>          p:=pc^.At(0);       {Вытащить первый элемент}<br>          Pc^.AtDelete(0);    {Удалить его из коллекции}<br>          Tec^.Insert(p);     {Добавить в текущую}<br>          Inc(Ts);            {Следующая колекция}<br>          Tec:=Bas^.At(Ts);   {Достать следующию колекцию}<br>     End;<br>     If tec^.Count=0 then<br>     Begin<br>      Bas^.Delete(Tec);<br>      Dispose(Tec,Done);<br>     End;<br>End;<br><br>Procedure Tlcol.AtFree(Index:Longint);<br>var item:Pointer;<br>Begin<br>     Item:=at(Index);<br>     AtDelete(Index);<br>     FreeItem(Item);<br>End;<br><br>Procedure Tlcol.AtInsert(Index:Longint;Item:Pointer);<br>var P:Pointer;<br>Begin<br>      Sh(Index);<br>      Tec^.AtInsert(Inx,Item);              {Вставить в текущую}<br>      While Tec^.Count>16300 Do             {балансировка колекции}<br>      Begin                                 {}<br>         p:=Tec^.At(16300);                 {берем последний}<br>         Tec^.AtDelete(16300);              {удаляем}<br>         If ts=Bas^.Count-1 then            {если коллекция последняя}<br>         Begin<br>           Tec:=New(Pcollection,Init(Start,Delta));<br>           Bas^.Insert(tec);<br>         End else tec:=Bas^.At(Ts+1);<br>         Tec^.AtInsert(0,p);                {Вставить в начало}<br>         Inc(Ts);<br>      End;<br>      Inc(Count);<br>End;<br><br>Procedure Tlcol.AtPut(Index:Longint;Item:Pointer);<br>Begin<br>     Sh(Index);<br>     Tec^.AtPut(Inx,Item);<br>End;<br><br>Procedure Tlcol.Delete(Item:Pointer);<br>Begin<br>     AtDelete(IndexOf(Item));<br>End;<br><br>Procedure Tlcol.DeleteAll;<br>var  Pc:Pcollection;<br>Procedure Del(pc:Pcollection);Far;<br>Begin<br>     Pc^.DeleteAll;<br>End;<br>Begin<br>     Bas^.ForEach(@del);<br>     Dispose(Bas,Done);<br>     Bas:=New(Pcollection,Init(1,1));<br>     tec:=New(Pcollection,Init(start,Delta));<br>     bas^.Insert(tec);<br>     Count:=0;<br>End;<br><br>Function Tlcol.FirstThat(P:Pointer):Pointer;<br>var po:Pointer;<br>Function Ac(pc:Pcollection):Boolean;Far;<br>Begin<br>    Po:=Pc^.FirstThat(P);<br>    Ac:=Po<>nil;<br>End;<br><br>Begin<br>    Po:=Nil;<br>    Bas^.FirstThat(@Ac);<br>    FirstThat:=Po;<br>End;<br><br>Function Tlcol.LastThat(P:Pointer):Pointer;<br>var po:Pointer;<br>Function Ac(pc:Pcollection):Boolean;Far;<br>Begin<br>    Po:=Pc^.LastThat(P);<br>    Ac:=Po<>nil;<br>End;<br><br>Begin<br>    Po:=Nil;<br>    Bas^.LastThat(@Ac);<br>    LastThat:=Po;<br>End;<br><br>Procedure Tlcol.ForEach(P:Pointer);<br>Procedure All(pc:Pcollection);Far;<br>Begin<br>     Pc^.ForEach(p);<br>End;<br>Begin<br>    Bas^.ForEach(@all);<br>End;<br><br>Procedure Tlcol.Free(Item:Pointer);<br>begin<br>  Delete(Item);<br>  FreeItem(Item);<br>end;<br><br>Procedure Tlcol.FreeAll;<br>var l:Longint;<br>Begin<br>     For l:=0 to count-1 Do FreeItem(At(l));<br>     Count:=0;<br>End;<br><br>Function Tlcol.IndexOf(Item:Pointer):Longint;<br>var Pc:Pcollection;<br>    Li,Oi:Integer;<br>Function Ser(Pcol:Pcollection):Boolean;Far;<br>Begin<br>    Li:=Pcol^.IndexOf(Item);<br>    Ser:=Li<>-1;<br>End;<br>Begin<br>    IndexOf:=-1;<br>    Pc:=bas^.FirstThat(@ser);<br>    If Pc=nil then exit;<br>    Oi:=bas^.IndexOf(PC);<br>    IndexOf:=Oi*16300+Li;<br>End;<br><br>Procedure Tlcol.Insert(Item:Pointer);<br>Begin<br>  tec:=Bas^.At(Bas^.Count-1); {Добыть последнюю}<br>  If tec^.Count<16300 then    {Если в ней есть свободные элементы}<br>    Tec^.Insert(Item) else<br>  Begin                       {Иначе заводим следующий банк с коллекцией}<br>    tec:=New(Pcollection,Init(Start,Delta)); {Новая коллекция}<br>    bas^.Insert(Tec);         {Добавить элемент}<br>    Tec^.Insert(Item);        {Добавить}<br>  End;<br>  Inc(Count);<br>End;<br><br>Procedure Tlcol.FreeItem(Item:Pointer);<br>Begin<br>    Dispose(Pobject(Item),Done);<br>End;<br><br>Procedure Tlcol.Sh(l:Longint);<br>{Procedure Error;<br>Begin<br>    Writeln('Ошибка TLCOL');<br>    Halt(0);<br>End;}<br>Begin<br>    Inx:=L mod 16300;<br>    Ts:=L div 16300;<br>    Tec:=Bas^.At(Ts);<br>End;<br><br><br>End.</pre>|lcol.zip|2185|02.07.1999|10.06.2002|217.106.58.2||alex_topaz
