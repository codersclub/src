Z||000002||Jimmy||05-22-2001||09:37 AM||cube@freemail.ru||CREATE PROCEDURE login_user<br>	@Login varchar (100),<br>	@Password varchar (100),<br>	@u_ID int OUTPUT<br>AS<br>	IF EXISTS (SELECT u_ID FROM users WHERE u_Login=@Login AND u_Password=@Password)<br>	BEGIN<br>		SELECT @u_ID=u_ID FROM users WHERE u_Login=@Login AND u_Password=@Password<br>		UPDATE users SET u_LastLogin=GETDATE() WHERE u_ID=@u_ID<br>		RETURN(1)<br>	END<br>	ELSE<br>		RETURN(0)	<br>	<br>GO
