A||||1||Marsel||аппроксимация
Z||000000||Marsel||10-13-2001||01:09 PM||davidovm@mail.ru||Нужна программа для аппроксимации методом наименьших квадратов, подскажите где взять.
Z||000001||Alone God||11-02-2001||06:21 PM||alone_god@mail.ru||Вот, из старых запасов:<p>Program Ex1ForEGA;<br>  Uses Graph,PGraph;<br>  Const<br>    Nmax=50;<br>  Var<br>    a:array [0..1] of real;<br>    b:array [0..2] of real;<br>    c:array [0..3] of real;<br>    x,y:array [1..Nmax] of real;<br>    f:text;<br>    n,i,j:integer;<br>    u:array [1..4,1..4] of real;<br>    r:array [1..4] of real;<br>    MaxX,MinX,KX,MaxY,MinY,KY:real;<br>    St1,St2,St3:string;<p>  Function f1(x:real):real;<br>    Begin<br>      f1:=a[0]+a[1]*x;<br>    End;<p>  Function f2(x:real):real;<br>    Begin<br>      f2:=b[0]+b[1]*x+b[2]*x*x;<br>    End;<p>  Function f3(x:real):real;<br>    Begin<br>      f3:=c[0]+c[1]*x+c[2]*x*x+c[3]*x*x*x;<br>    End;<p>  Procedure PStep(n1,n2:byte);<br>    Var<br>      i,j:byte;<br>    Begin<br>      if n1=n2 then<br>       begin<br>	r[n1]:=r[n1]/u[n1,n1];<br>	u[n1,n1]:=1;<br>	Exit;<br>       end;<br>      r[n1]:=r[n1]/u[n1,n1];<br>      For i:=n1+1 to n2 do<br>       u[n1,i]:=u[n1,i]/u[n1,n1];<br>      u[n1,n1]:=1;<br>      For i:=n1+1 to n2 do<br>       begin<br>	For j:=n1+1 to n2 do<br>	 u[i,j]:=u[i,j]-u[i,n1]*u[n1,j];<br>	r[i]:=r[i]-u[i,n1]*r[n1];<br>	u[i,n1]:=0;<br>       end;<br>      PStep(n1+1,n2);<br>    End;<p>  Procedure OStep(n:byte);<br>    Var<br>      Sv:real;<br>      i,j,k:byte;<br>    Begin<br>      for i:=n downto 2 do<br>       For j:=1 to i-1 do<br>	begin<br>	 Sv:=u[j,i];<br>	 For k:=1 to n do<br>	  u[j,k]:=u[j,k]-Sv*u[i,k];<br>	 r[j]:=r[j]-Sv*r[i];<br>	end;<br>    End;<p><br>  Begin<p>    Assign(f,'EX1.DAT'{ParamStr(1)});<br>    Reset(f);<br>    Readln(f,n);<br>    If n&gt;Nmax then Exit;<br>    For i:=1 to n do<br>     Readln(f,x[i],y[i]);<p>    n:=n-1;<p>    For i:=1 to 2 do<br>     For j:=1 to 2 do<br>      begin<br>       u[i,j]:=0;<br>       r[i]:=0;<br>      end;<br>    For i:=1 to n do<br>     begin<br>      u[1,1]:=u[1,1]+1;<br>      u[1,2]:=u[1,2]+x[i];<br>      u[2,1]:=u[2,1]+x[i];<br>      u[2,2]:=u[2,2]+x[i]*x[i];<br>      r[1]:=r[1]+y[i];<br>      r[2]:=r[2]+x[i]*y[i];<br>     end;<br>    PStep(1,2);<br>    OStep(2);<br>    For i:=0 to 1 do<br>     a[i]:=r[i+1];<p>    For i:=1 to 3 do<br>     For j:=1 to 3 do<br>      begin<br>       u[i,j]:=0;<br>       r[i]:=0;<br>      end;<br>    For i:=1 to n do<br>     begin<br>      u[1,1]:=u[1,1]+1;<br>      u[1,2]:=u[1,2]+x[i];<br>      u[1,3]:=u[1,3]+x[i]*x[i];<br>      u[2,1]:=u[2,1]+x[i];<br>      u[2,2]:=u[2,2]+x[i]*x[i];<br>      u[2,3]:=u[2,3]+x[i]*x[i]*x[i];<br>      u[3,1]:=u[3,1]+x[i]*x[i];<br>      u[3,2]:=u[3,2]+x[i]*x[i]*x[i];<br>      u[3,3]:=u[3,3]+x[i]*x[i]*x[i]*x[i];<br>      r[1]:=r[1]+y[i];<br>      r[2]:=r[2]+x[i]*y[i];<br>      r[3]:=r[3]+x[i]*x[i]*y[i];<br>     end;<br>    PStep(1,3);<br>    OStep(3);<br>    For i:=0 to 2 do<br>     b[i]:=r[i+1];<p>    For i:=1 to 4 do<br>     For j:=1 to 4 do<br>      begin<br>       u[i,j]:=0;<br>       r[i]:=0;<br>      end;<br>    For i:=1 to n do<br>     begin<br>      u[1,1]:=u[1,1]+1;<br>      u[1,2]:=u[1,2]+x[i];<br>      u[1,3]:=u[1,3]+x[i]*x[i];<br>      u[1,4]:=u[1,4]+x[i]*x[i]*x[i];<br>      u[2,1]:=u[2,1]+x[i];<br>      u[2,2]:=u[2,2]+x[i]*x[i];<br>      u[2,3]:=u[2,3]+x[i]*x[i]*x[i];<br>      u[2,4]:=u[3,3]+x[i]*x[i]*x[i]*x[i];<br>      u[3,1]:=u[3,1]+x[i]*x[i];<br>      u[3,2]:=u[3,2]+x[i]*x[i]*x[i];<br>      u[3,3]:=u[3,3]+x[i]*x[i]*x[i]*x[i];<br>      u[3,4]:=u[3,4]+x[i]*x[i]*x[i]*x[i]*x[i];<br>      u[4,1]:=u[4,1]+x[i]*x[i]*x[i];<br>      u[4,2]:=u[4,2]+x[i]*x[i]*x[i]*x[i];<br>      u[4,3]:=u[4,3]+x[i]*x[i]*x[i]*x[i]*x[i];<br>      u[4,4]:=u[4,4]+x[i]*x[i]*x[i]*x[i]*x[i]*x[i];<br>      r[1]:=r[1]+y[i];<br>      r[2]:=r[2]+x[i]*y[i];<br>      r[3]:=r[3]+x[i]*x[i]*y[i];<br>      r[4]:=r[4]+x[i]*x[i]*x[i]*y[i];<br>     end;<br>    PStep(1,4);<br>    OStep(4);<br>    For i:=0 to 3 do<br>     c[i]:=r[i+1];<p>    n:=n+1;<p>    MaxX:=x[1];<br>    MinX:=x[1];<br>    For i:=2 to n do<br>     begin<br>      if MaxX&lt;x[i] then MaxX:=x[i];<br>      if MinX&gt;x[i] then MinX:=x[i];<br>     end;<br>    KX:=460/(MaxX-MinX);<br>    MaxY:=y[1];<br>    MinY:=y[1];<br>    For i:=2 to n do<br>     begin<br>      if MaxY&lt;y[i] then MaxY:=y[i];<br>      if MinY&gt;y[i] then MinY:=y[i];<br>     end;<br>    For i:=30 to 490 do<br>     begin<br>      if MaxY&lt;f1((i-30)/KX+MinX) then MaxY:=f1((i-30)/KX+MinX);<br>      if MinY&gt;f1((i-30)/KX+MinX) then MinY:=f1((i-30)/KX+MinX);<br>      if MaxY&lt;f2((i-30)/KX+MinX) then MaxY:=f2((i-30)/KX+MinX);<br>      if MinY&gt;f2((i-30)/KX+MinX) then MinY:=f2((i-30)/KX+MinX);<br>      if MaxY&lt;f3((i-30)/KX+MinX) then MaxY:=f3((i-30)/KX+MinX);<br>      if MinY&gt;f3((i-30)/KX+MinX) then MinY:=f3((i-30)/KX+MinX);<br>     end;<br>    KY:=420/(MaxY-MinY);<br>    OpenGraph;<br>    SetColor(White);<br>    Rectangle(20,20,500,460);<br>    Rectangle(500,20,620,460);<br>    Rectangle(500,20,620,70);<br>    Rectangle(500,140,620,230);<br>    if MinX*MaxX&lt;=0 then<br>     begin<br>      Line(30-round(KX*MinX),30,30-round(KX*MinX),450);<br>      Line(30-round(KX*MinX),30,25-round(KX*MinX),50);<br>      Line(30-round(KX*MinX),30,35-round(KX*MinX),50);<br>      Line(25-round(KX*MinX),50,35-round(KX*MinX),50);<br>     end;<br>    if MinY*MaxY&lt;=0 then<br>     begin<br>      Line(30,450+round(KY*MinY),490,450+round(KY*MinY));<br>      Line(490,450+round(KY*MinY),470,455+round(KY*MinY));<br>      Line(490,450+round(KY*MinY),470,445+round(KY*MinY));<br>      Line(470,455+round(KY*MinY),470,445+round(KY*MinY));<br>     end;<br>    SetColor(Red);<br>    Line(30,450-round(KY*(f1(MinX)-MinY)),<br>         490,450-round(KY*(f1(MaxX)-MinY)));<br>    SetColor(Green);<br>    MoveTo(30,450-round(KY*(f2(MinX)-MinY)));<br>    For i:=31 to 490 do<br>     begin<br>      LineTo(i,450-round(KY*(f2((i-30)/KX+MinX)-MinY)));<br>     end;<br>    SetColor(Blue);<br>    MoveTo(30,450-round(KY*(f3(MinX)-MinY)));<br>    For i:=31 to 490 do<br>     begin<br>      LineTo(i,450-round(KY*(f3((i-30)/KX+MinX)-MinY)));<br>     end;<br>    SetColor(Yellow);<br>    SetFillStyle(1,Yellow);<br>    For i:=1 to n do<br>     begin<br>      FillEllipse(30+round(KX*(x[i]-MinX)),450-round(KY*(y[i]-MinY)),2,2);<br>     end;<br>    SetColor(Red);<br>    For i:=0 to 1 do<br>     begin<br>      Str(i,St1);<br>      Str(a[i]:-10:5,St2);<br>      St3:='a'+St1+'='+St2;<br>      OutTextXY(510,i*20+30,St3);<br>     end;<br>    SetColor(Green);<br>    For i:=0 to 2 do<br>     begin<br>      Str(i,St1);<br>      Str(b[i]:-10:5,St2);<br>      St3:='b'+St1+'='+St2;<br>      OutTextXY(510,i*20+80,St3);<br>     end;<br>    SetColor(Blue);<br>    For i:=0 to 3 do<br>     begin<br>      Str(i,St1);<br>      Str(c[i]:-10:5,St2);<br>      St3:='c'+St1+'='+St2;<br>      OutTextXY(510,i*20+150,St3);<br>     end;<br>    Readln;<br>    CloseGraph;<br>  End.
